    {
      "type": "text", "id": "layer3_detail", "x": 1025, "y": 1000, "width": 360, "height": 150,
      "text": "Unix socket:\n  /run/<app>/secret-proxy.sock\n\nallowedUsers: [<svc-uid>]\n\nPer-command secret scoping:\n  svc_a_key -> svc_a only\n  svc_b_pat -> svc_b only\n  svc_c_key -> svc_c only\n\nRate limit: 60/min, 5 max\nCommand timeout: 30s",
      "originalText": "Unix socket:\n  /run/<app>/secret-proxy.sock\n\nallowedUsers: [<svc-uid>]\n\nPer-command secret scoping:\n  svc_a_key -> svc_a only\n  svc_b_pat -> svc_b only\n  svc_c_key -> svc_c only\n\nRate limit: 60/min, 5 max\nCommand timeout: 30s",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#ffffff", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
