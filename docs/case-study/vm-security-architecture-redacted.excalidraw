    {
      "type": "text", "id": "layer2_detail", "x": 615, "y": 1000, "width": 360, "height": 150,
      "text": "systemd reads root-owned\nfiles at service start\n\nExposes via tmpfs-backed\n$CREDENTIALS_DIRECTORY\n\nApp process reads\nfrom tmpfs, never from\n/etc/<app>/secrets/\n\n7 credentials loaded",
      "originalText": "systemd reads root-owned\nfiles at service start\n\nExposes via tmpfs-backed\n$CREDENTIALS_DIRECTORY\n\nApp process reads\nfrom tmpfs, never from\n/etc/<app>/secrets/\n\n7 credentials loaded",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid",
